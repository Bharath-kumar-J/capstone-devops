{
  "id": null,
  "uid": "adpqs9r",
  "title": "Requests Per Second",
  "tags": ["capstone"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests Per Second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 0, "showPoints": "auto" }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 10, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint, http_status) (rate(app_requests_total[1m]))",
          "legendFormat": "{{endpoint}} {{http_status}}"
        }
      ]
    }
  ]
}
